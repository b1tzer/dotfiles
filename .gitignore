# =============================================================================
# .gitignore for dotfiles management repository
# =============================================================================

# ---------------------------------------------------------------------------
# Sensitive files - NEVER commit these
# ---------------------------------------------------------------------------
secrets.local.env
secrets.local.*
*.local.env
.env
.env.local
.env.*.local

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
*.ppk

# Secret-named files
*_secret*
*_secrets*
*secret.yaml
*secret.yml
*secret.json
*secrets.yaml
*secrets.yml
*secrets.json
.secrets

# Credential files
.netrc
.npmrc.local
.pypirc
.aws/credentials
.ssh/

# ---------------------------------------------------------------------------
# OS generated files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Editor & IDE files
# ---------------------------------------------------------------------------
.idea/
.vscode/settings.json
*.swp
*.swo
*~
.vim/undo/
.vim/backup/

# ---------------------------------------------------------------------------
# Logs & temporary files
# ---------------------------------------------------------------------------
*.log
sync.log
*.tmp
*.bak
*.bak.*
backup/

# ---------------------------------------------------------------------------
# Package manager caches (if any scripts generate these)
# ---------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc

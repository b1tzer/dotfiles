#!/usr/bin/env bash
# =============================================================================
# bin/dotfiles - 开发环境管理工具入口脚本
# =============================================================================
# 用法：
#   ./bin/dotfiles <subcommand> [options]
#   ./bin/dotfiles --help
#
# 子命令：
#   sync      同步工具安装 + dotfiles 链接
#   update    git pull + sync（拉取最新配置后同步）
#   doctor    检查环境健康状态
#   status    显示当前安装/链接状态（doctor 的别名）
#   cache     管理下载缓存
#   test      运行测试套件
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ---------------------------------------------------------------------------
# 加载 lib 模块（带缺失检测守卫）
# ---------------------------------------------------------------------------
_require_lib() {
  local lib_file="$REPO_ROOT/lib/$1"
  if [[ ! -f "$lib_file" ]]; then
    printf "  [✗]  error: required module 'lib/%s' not found. Is your repo complete?\n" "$1" >&2
    printf "         hint:  Run: git status  to check for missing files.\n" >&2
    exit 127
  fi
  # shellcheck source=/dev/null
  source "$lib_file"
}

_require_lib "logging.sh"

# ---------------------------------------------------------------------------
# 顶层帮助信息
# ---------------------------------------------------------------------------
_show_help() {
  cat <<'EOF'

dotfiles — 开发环境管理工具

USAGE:
  ./bin/dotfiles <subcommand> [options]
  ./bin/dotfiles --help

SUBCOMMANDS:
  Sync & Update
    sync      Sync tool installations and dotfile symlinks
    update    Pull latest config from git, then sync

  Diagnostics
    doctor    Check environment health (tools, dotfiles, secrets)
    status    Alias for doctor

  Maintenance
    cache     Manage local download cache
    test      Run test suite

Run './bin/dotfiles <subcommand> --help' for subcommand-specific options.

EXAMPLES:
  ./bin/dotfiles sync                    # Full sync (tools + dotfiles)
  ./bin/dotfiles sync --only git,jq      # Only sync specific tools
  ./bin/dotfiles update                  # Pull latest + full sync
  ./bin/dotfiles doctor                  # Check environment health
  ./bin/dotfiles cache status            # Show cache usage

EOF
}

# ---------------------------------------------------------------------------
# 未知子命令提示（前缀匹配 "Did you mean?"）
# ---------------------------------------------------------------------------
_suggest_command() {
  local input="$1"
  local known_cmds=("sync" "update" "doctor" "status" "cache" "test")
  local suggestions=()

  # 前缀匹配（cmd 以 input 开头）
  for cmd in "${known_cmds[@]}"; do
    if [[ "$cmd" == "${input}"* ]]; then
      suggestions+=("$cmd")
    fi
  done

  # 反向前缀匹配（input 以 cmd 开头，如 syncc → sync）
  if [[ "${#suggestions[@]}" -eq 0 ]]; then
    for cmd in "${known_cmds[@]}"; do
      if [[ "$input" == "${cmd}"* ]]; then
        suggestions+=("$cmd")
      fi
    done
  fi

  # 若无前缀匹配，尝试包含匹配
  if [[ "${#suggestions[@]}" -eq 0 ]]; then
    for cmd in "${known_cmds[@]}"; do
      if [[ "$cmd" == *"${input}"* ]]; then
        suggestions+=("$cmd")
      fi
    done
  fi

  printf "  [✗]  error: unknown command '%s'.\n" "$input" >&2
  if [[ "${#suggestions[@]}" -gt 0 ]]; then
    printf "         Did you mean '%s'?\n" "${suggestions[0]}" >&2
  fi
  printf "         Run './bin/dotfiles --help' to see available commands.\n" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# 子命令：sync
# ---------------------------------------------------------------------------
_cmd_sync() {
  local sync_script="$REPO_ROOT/scripts/sync.sh"
  local link_script="$REPO_ROOT/scripts/link_dotfiles.sh"

  # 解析 sync 专属 flag
  local do_tools=true
  local do_dotfiles=true
  local passthrough_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tools)     do_dotfiles=false ; shift ;;
      --dotfiles)  do_tools=false    ; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: dotfiles sync [options]

Options:
  --tools             Only sync tool installations, skip dotfiles linking
  --dotfiles          Only link dotfiles, skip tool installations
  --only <tools>      Only process specified tools (comma-separated)
  --skip-runtimes     Skip mise-managed runtime installations
  --force, -f         Reinstall tools even if already installed
  --dry-run           Preview changes without making modifications
  --quiet, -q         Only output errors and final summary
  -h, --help          Show this help message

Examples:
  dotfiles sync                        # Full sync
  dotfiles sync --tools                # Tools only
  dotfiles sync --dotfiles             # Dotfiles only
  dotfiles sync --only git,ripgrep     # Sync specific tools
  dotfiles sync --dry-run              # Preview changes
  dotfiles sync --force                # Force reinstall
EOF
        exit 0
        ;;
      *) passthrough_args+=("$1") ; shift ;;
    esac
  done

  if [[ "$do_tools" == "true" ]]; then
    if [[ ! -f "$sync_script" ]]; then
      _error_actionable \
        "sync.sh not found at: $sync_script" \
        "The scripts/ directory may be incomplete" \
        "Run: git status  to check for missing files"
      exit 1
    fi
    bash "$sync_script" "${passthrough_args[@]}"
  fi

  if [[ "$do_dotfiles" == "true" ]]; then
    if [[ ! -f "$link_script" ]]; then
      _error_actionable \
        "link_dotfiles.sh not found at: $link_script" \
        "The scripts/ directory may be incomplete" \
        "Run: git status  to check for missing files"
      exit 1
    fi
    # 将 --dry-run 透传给 link_dotfiles.sh
    local link_args=()
    for arg in "${passthrough_args[@]:-}"; do
      [[ "$arg" == "--dry-run" ]] && link_args+=("--dry-run")
    done
    bash "$link_script" "${link_args[@]}"
  fi
}

# ---------------------------------------------------------------------------
# 子命令：update（git pull + sync）
# ---------------------------------------------------------------------------
_cmd_update() {
  local passthrough_args=("$@")

  # 解析 --help
  for arg in "$@"; do
    if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
      cat <<'EOF'
Usage: dotfiles update [sync-options]

Pull the latest configuration from git, then run a full sync.
Equivalent to: git pull --ff-only && dotfiles sync

Options:
  All options from 'dotfiles sync' are supported.
  -h, --help    Show this help message

Examples:
  dotfiles update                  # Pull + full sync
  dotfiles update --dry-run        # Pull + preview changes
EOF
      exit 0
    fi
  done

  _section "Pulling latest configuration"

  if ! git -C "$REPO_ROOT" rev-parse --git-dir &>/dev/null; then
    _warn "Not a git repository. Skipping pull."
  else
    local current_branch
    current_branch="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo 'unknown')"
    _info "Branch: $current_branch"
    git -C "$REPO_ROOT" pull --ff-only
    _ok "Repository updated"
  fi

  _cmd_sync "${passthrough_args[@]}"
}

# ---------------------------------------------------------------------------
# 子命令：doctor / status
# ---------------------------------------------------------------------------
_cmd_doctor() {
  local doctor_script="$REPO_ROOT/scripts/doctor.sh"

  # 解析 --help
  for arg in "$@"; do
    if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
      cat <<'EOF'
Usage: dotfiles doctor [options]

Check the health of your development environment.
Inspects: tool installations, dotfile symlinks, secrets, lib modules.

Options:
  -h, --help    Show this help message

Exit codes:
  0 - Environment is healthy (or only warnings)
  1 - One or more critical issues found

Examples:
  dotfiles doctor          # Full health check
  dotfiles status          # Alias for doctor
EOF
      exit 0
    fi
  done

  if [[ ! -f "$doctor_script" ]]; then
    _error_actionable \
      "doctor.sh not found at: $doctor_script" \
      "The scripts/ directory may be incomplete" \
      "Run: git status  to check for missing files"
    exit 1
  fi

  bash "$doctor_script" "$@"
}

# ---------------------------------------------------------------------------
# 子命令：cache（内联逻辑，无需外部脚本）
# ---------------------------------------------------------------------------

DOTFILES_CACHE_DIR="${DOTFILES_CACHE_DIR:-$HOME/.cache/dotfiles}"
DOTFILES_CACHE_TTL_DAYS="${DOTFILES_CACHE_TTL_DAYS:-7}"

# 格式化文件大小（人类可读）
_format_size() {
  local bytes="$1"
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(echo "scale=1; $bytes / 1073741824" | bc)"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(echo "scale=1; $bytes / 1048576" | bc)"
  elif (( bytes >= 1024 )); then
    printf "%.1f KB" "$(echo "scale=1; $bytes / 1024" | bc)"
  else
    printf "%d B" "$bytes"
  fi
}

# 获取文件修改时间（跨平台）
_file_mtime() {
  local file="$1"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    stat -f %m "$file" 2>/dev/null || echo 0
  else
    stat -c %Y "$file" 2>/dev/null || echo 0
  fi
}

# cache status：列出所有缓存条目
_cache_status() {
  if [[ ! -d "$DOTFILES_CACHE_DIR" ]]; then
    _info "Cache directory does not exist: $DOTFILES_CACHE_DIR"
    _info "No cached files found."
    return 0
  fi

  echo
  echo "  Cache directory: $DOTFILES_CACHE_DIR"
  echo "  TTL: $DOTFILES_CACHE_TTL_DAYS days"
  echo

  local total_bytes=0
  local file_count=0
  local now
  now="$(date +%s)"
  local ttl_seconds=$(( DOTFILES_CACHE_TTL_DAYS * 86400 ))

  printf "  %-50s  %8s  %-20s  %s\n" "FILE" "SIZE" "CACHED AT" "STATUS"
  printf "  %-50s  %8s  %-20s  %s\n" "$(printf '%0.s─' {1..50})" "$(printf '%0.s─' {1..8})" "$(printf '%0.s─' {1..20})" "$(printf '%0.s─' {1..10})"

  while IFS= read -r -d '' file; do
    [[ -f "$file" ]] || continue

    local rel_path="${file#$DOTFILES_CACHE_DIR/}"
    local file_size
    file_size="$(wc -c < "$file" 2>/dev/null || echo 0)"
    local mtime
    mtime="$(_file_mtime "$file")"
    local cached_at
    cached_at="$(date -d "@$mtime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -r "$mtime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'unknown')"
    local age=$(( now - mtime ))
    local status

    if (( age < ttl_seconds )); then
      local remaining=$(( (ttl_seconds - age) / 86400 ))
      status="valid (${remaining}d left)"
    else
      status="expired"
    fi

    printf "  %-50s  %8s  %-20s  %s\n" \
      "${rel_path:0:50}" \
      "$(_format_size "$file_size")" \
      "$cached_at" \
      "$status"

    total_bytes=$(( total_bytes + file_size ))
    file_count=$(( file_count + 1 ))
  done < <(find "$DOTFILES_CACHE_DIR" -type f -print0 2>/dev/null | sort -z)

  echo
  if [[ "$file_count" -eq 0 ]]; then
    _info "No cached files found."
  else
    printf "  Total: %d files, %s\n" "$file_count" "$(_format_size "$total_bytes")"
  fi
  echo
}

# cache clear：删除所有缓存文件
_cache_clear() {
  if [[ ! -d "$DOTFILES_CACHE_DIR" ]]; then
    _info "Cache directory does not exist. Nothing to clear."
    return 0
  fi

  local total_bytes=0
  while IFS= read -r -d '' file; do
    [[ -f "$file" ]] || continue
    local file_size
    file_size="$(wc -c < "$file" 2>/dev/null || echo 0)"
    total_bytes=$(( total_bytes + file_size ))
  done < <(find "$DOTFILES_CACHE_DIR" -type f -print0 2>/dev/null)

  if [[ "$total_bytes" -eq 0 ]]; then
    _info "Cache is already empty."
    return 0
  fi

  _info "Clearing cache: $DOTFILES_CACHE_DIR"
  rm -rf "${DOTFILES_CACHE_DIR:?}"/*
  _ok "Cache cleared. Freed: $(_format_size "$total_bytes")"
}

_cmd_cache() {
  local action="${1:-}"

  case "$action" in
    status)
      _cache_status
      ;;
    clear)
      _cache_clear
      ;;
    ""|--help|-h)
      cat <<'EOF'
Usage: dotfiles cache <action>

Manage the local download cache used to avoid re-downloading resources.

Actions:
  status    List all cached files with size and expiry info
  clear     Delete all cached files and show freed disk space

Options:
  -h, --help    Show this help message

Examples:
  dotfiles cache status    # Show cache contents
  dotfiles cache clear     # Clear all cached files
EOF
      ;;
    *)
      printf "  [✗]  error: unknown cache action '%s'\n" "$action" >&2
      printf "         hint:  Use 'status' or 'clear'\n" >&2
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# 子命令：test
# ---------------------------------------------------------------------------
_cmd_test() {
  local tests_dir="$REPO_ROOT/tests"
  local run_integration=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --integration) run_integration=true ; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: dotfiles test [options]

Run the test suite. By default, only unit tests are run (no network required).

Options:
  --integration    Also run integration tests (uses cache, avoids re-downloads)
  -h, --help       Show this help message

Exit codes:
  0 - All tests passed
  1 - One or more tests failed

Examples:
  dotfiles test                  # Run unit tests only (< 30s)
  dotfiles test --integration    # Run all tests
EOF
        exit 0
        ;;
      *) _warn "Unknown test option: $1" ; shift ;;
    esac
  done

  if [[ ! -d "$tests_dir" ]]; then
    _error_actionable \
      "tests/ directory not found" \
      "The test suite has not been set up yet" \
      "Check the repository for tests/ directory"
    exit 1
  fi

  local failed=0
  local passed=0

  _section "Running unit tests"
  for test_file in "$tests_dir/unit"/test_*.sh; do
    [[ -f "$test_file" ]] || continue
    local test_name
    test_name="$(basename "$test_file")"
    if bash "$test_file"; then
      _ok "PASS: $test_name"
      passed=$(( passed + 1 ))
    else
      _error "FAIL: $test_name"
      failed=$(( failed + 1 ))
    fi
  done

  if [[ "$run_integration" == "true" ]]; then
    _section "Running integration tests"
    for test_file in "$tests_dir/integration"/test_*.sh; do
      [[ -f "$test_file" ]] || continue
      local test_name
      test_name="$(basename "$test_file")"
      if bash "$test_file"; then
        _ok "PASS: $test_name"
        passed=$(( passed + 1 ))
      else
        _error "FAIL: $test_name"
        failed=$(( failed + 1 ))
      fi
    done
  fi

  echo
  echo "  Results: $passed passed, $failed failed"
  echo

  [[ "$failed" -eq 0 ]]
}

# ---------------------------------------------------------------------------
# Main 入口：子命令分发
# ---------------------------------------------------------------------------
main() {
  # 无参数或 --help：显示帮助
  if [[ $# -eq 0 ]] || [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    _show_help
    exit 0
  fi

  local subcommand="$1"
  shift

  case "$subcommand" in
    sync)    _cmd_sync    "$@" ;;
    update)  _cmd_update  "$@" ;;
    doctor)  _cmd_doctor  "$@" ;;
    status)  _cmd_doctor  "$@" ;;  # status 是 doctor 的别名
    cache)   _cmd_cache   "$@" ;;
    test)    _cmd_test    "$@" ;;
    *)       _suggest_command "$subcommand" ;;
  esac
}

main "$@"

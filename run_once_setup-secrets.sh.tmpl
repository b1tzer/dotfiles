#!/usr/bin/env bash
# =============================================================================
# run_once_setup-secrets.sh - Initialize local secrets file
# =============================================================================
# Managed by chezmoi. Runs ONCE on first `chezmoi apply`.
# Delegates to the existing init_secrets.sh wizard.
#
# To force re-run:
#   chezmoi state delete-bucket --bucket=scriptState
#   chezmoi apply
# =============================================================================

set -euo pipefail

SECRETS_LOCAL="$HOME/.secrets.local.env"
CHEZMOI_SOURCE_DIR="{{ .chezmoi.sourceDir }}"
INIT_SECRETS_SCRIPT="$CHEZMOI_SOURCE_DIR/scripts/init_secrets.sh"

# Skip if already configured
if [ -f "$SECRETS_LOCAL" ]; then
  echo "[chezmoi] ~/.secrets.local.env already exists. Skipping secrets setup."
  exit 0
fi

if [ ! -f "$INIT_SECRETS_SCRIPT" ]; then
  echo "[chezmoi] init_secrets.sh not found. Skipping."
  exit 0
fi

echo "[chezmoi] Setting up local secrets..."
bash "$INIT_SECRETS_SCRIPT"

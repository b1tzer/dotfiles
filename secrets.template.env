# =============================================================================
# secrets.template.env - Sensitive Configuration Template
# =============================================================================
# This file is committed to Git as a TEMPLATE ONLY.
# DO NOT fill in real values here.
#
# Usage:
#   On a new machine, run: scripts/init_secrets.sh
#   It will read this file and guide you to create secrets.local.env
#   with your actual values. secrets.local.env is gitignored.
#
# Format:
#   KEY=PLACEHOLDER|description|required(yes/no)
# =============================================================================

# GitHub personal access token (for gh CLI auth, private repo access)
GITHUB_TOKEN=CHANGE_ME|GitHub Personal Access Token (Settings > Developer settings > PAT)|yes

# NPM auth token (for publishing packages or accessing private registries)
NPM_TOKEN=CHANGE_ME|NPM authentication token (npmjs.com > Access Tokens)|no

# AWS credentials
AWS_ACCESS_KEY_ID=CHANGE_ME|AWS Access Key ID|no
AWS_SECRET_ACCESS_KEY=CHANGE_ME|AWS Secret Access Key|no
AWS_DEFAULT_REGION=us-east-1|AWS default region (not sensitive, can be changed)|no

# Docker Hub credentials (for docker login)
DOCKER_USERNAME=CHANGE_ME|Docker Hub username|no
DOCKER_PASSWORD=CHANGE_ME|Docker Hub password or access token|no

# SSH key passphrase (leave empty if your SSH key has no passphrase)
SSH_KEY_PASSPHRASE=CHANGE_ME|Passphrase for your SSH private key (leave empty if none)|no

# Git global config (not sensitive, but machine-specific)
GIT_USER_NAME=CHANGE_ME|Your full name for git commits (e.g. John Doe)|yes
GIT_USER_EMAIL=CHANGE_ME|Your email for git commits (e.g. john@example.com)|yes

# Proxy settings (if behind a corporate proxy)
HTTP_PROXY=|HTTP proxy URL (e.g. http://proxy.company.com:8080), leave empty if not needed|no
HTTPS_PROXY=|HTTPS proxy URL, leave empty if not needed|no
NO_PROXY=localhost,127.0.0.1|Comma-separated list of hosts to bypass proxy|no

# Custom API keys (add your own below)
# EXAMPLE_API_KEY=CHANGE_ME|Description of what this key is for|no
